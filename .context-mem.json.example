{
  "storage": "auto",
  "plugins": {
    "summarizers": ["shell", "json", "error", "log", "code"],
    "search": ["bm25", "trigram"],
    "runtimes": ["javascript", "python"],
    "external_summarizers": {
      "context-mem-summarizer-k8s": { "enabled": true, "priority": 50 },
      "context-mem-summarizer-terraform": { "enabled": true }
    }
  },
  "privacy": {
    "strip_tags": true,
    "redact_patterns": []
  },
  "token_economics": true,
  "lifecycle": {
    "ttl_days": 30,
    "max_db_size_mb": 500,
    "max_observations": 50000,
    "cleanup_schedule": "on_startup",
    "preserve_types": ["decision", "commit"]
  },
  "search_weights": {
    "bm25": 0.5,
    "trigram": 0.3,
    "levenshtein": 0.15,
    "vector": 0.05
  },
  "proactive_injection": {
    "enabled": true,
    "max_injections_per_minute": 3,
    "file_cooldown_seconds": 300,
    "relevance_threshold": 0.6,
    "max_injection_chars": 500,
    "inject_on": ["Read", "Edit"]
  },
  "port": 51893,
  "db_path": ".context-mem/store.db"
}
